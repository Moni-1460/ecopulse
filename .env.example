# Copy this file to .env and fill in your own values.

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Any Groq-hosted chat model works; this default is fast and high quality.
GROQ_MODEL=llama-3.3-70b-versatile

# SQLite by default -- no external DB service required.
# Point this at Postgres/MySQL/MongoDB-compatible URL to swap databases.
DATABASE_URL=sqlite:///./data/ecopulse.db
